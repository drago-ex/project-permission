{
	"name": "drago-ex/project-permission",
	"type": "drago-tools-resource",
	"description": "Component for managing user permissions in a Drago project.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"nette/di": "^3.1",
		"nette/security": "^3.1",
		"nette/application": "^3.1",
		"drago-ex/component": "^2.0",
		"drago-ex/database": "^3.0",
		"drago-ex/utils": "^2.0",
		"drago-ex/application": "^2.0",
		"drago-ex/form": "^2.0",
		"drago-ex/permission": "^2.0",
		"drago-ex/translator": "^3.0",
		"drago-ex/project-front": "^2.0",
		"drago-ex/datagrid": "@dev"
	},
	"extra": {
		"drago-tools": {
			"install": {
				"copy": {
					"resources/Permission": "app/Core/Permission",
					"resources/app/UI/Backend": "app/UI/Backend",
					"resources/assets/naja": "assets/naja"
				}
			},
			"commands-priority": 20,
			"commands": {
				"db:migrate-permission": "php vendor/bin/migration db:migrate vendor/drago-ex/project-permission/migrations"
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2",
		"drago-ex/project-tools": "@dev"
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
