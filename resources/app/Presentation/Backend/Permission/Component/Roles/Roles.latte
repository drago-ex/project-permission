{templateType App\Presentation\Backend\Permission\Component\BaseTemplate}
{embed '../../../../Accessory/Widget/@offcanvas.latte', offcanvasId: $offcanvasId, size: '61rem'}
	{block title}{_'Manage Role'}{/block}
	{block body}
		{snippet offcanvas}
			{embed '../../../../Accessory/Widget/@form.latte', class: 'ajax', name: 'roles', najaHistory: 'off'}
				{import '../../../../Accessory/Widget/@dismiss-button.latte'}
				{block form}
					{include input, name: 'name'}
					{include input, name: 'description'}
					<div class="col-12">
						{include buttonDismiss, type: 'offcanvas'}
						{include submit, name: 'send'}
					</div>
				{/block}
			{/embed}
		{/snippet}
	{/block}
{/embed}

{embed '../../../../Accessory/Widget/@modal.latte', modalId: $modalId, options: [header: 'danger']}
	{block title}{_'Confirm delete'}{/block}
	{block body}
		{snippet content}
			{include '../@modal-body.latte'}
		{/snippet}
	{/block}
	{block footer}
		{snippet modal}
			{include '../@modal-footer.latte'}
		{/snippet}
	{/block}
{/embed}

{embed '../@datagrid-heading.latte', access: $user->isAllowed('Backend:Permission', 'roles-write')}
	{block title}
		{_'Roles data'}
	{/block}
{/embed}

{control dataGrid}
